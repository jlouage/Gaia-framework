# GAIA Framework — resolved configs (regenerated by /gaia-build-configs)
_gaia/**/.resolved/*.yaml
!_gaia/**/.resolved/.gitkeep

# Internal planning docs — not for distribution
docs/phases/

# Node
node_modules/
coverage/

# Memory — checkpoints are ephemeral, archive is pruned
_memory/checkpoints/
_memory/*-sidecar/archive/

# Figma MCP cached responses — never commit design data
.figma-cache/

# BATS test helpers (downloaded by test/shell/setup-bats.sh)
test/shell/test_helper/
