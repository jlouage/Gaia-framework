      },
      "$description": "Subtle shadow for cards and surfaces"
    },
    "md": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0px",
        "offsetY": "4px",
        "blur": "6px",
        "spread": "-1px",
        "color": "rgba(0, 0, 0, 0.1)"
      },
      "$description": "Medium shadow for elevated elements"
    },
    "lg": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0px",
